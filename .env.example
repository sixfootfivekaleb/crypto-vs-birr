# Crypto vs Birr - Environment Variables
# Copy this file to .env and fill in your API keys

# ===========================================
# EXCHANGE RATE API (Required)
# ===========================================
# Sign up at: https://www.exchangerate-api.com/
# Free tier: 1,500 requests/month
#
# Steps to get your API key:
# 1. Go to https://www.exchangerate-api.com/
# 2. Click "Get Free Key"
# 3. Enter your email address
# 4. Verify your email
# 5. Copy your API key from the dashboard
#
VITE_EXCHANGE_RATE_API_KEY=your_api_key_here

# ===========================================
# COINGECKO API (Optional - has free tier)
# ===========================================
# The free tier works without an API key (with rate limits)
# For higher limits, sign up at: https://www.coingecko.com/en/api
#
# Free tier limits: 10-30 calls/minute
# If you have a paid plan, add your API key here:
#
VITE_COINGECKO_API_KEY=

# ===========================================
# APP CONFIGURATION
# ===========================================
# Enable demo mode (uses mock data instead of real API calls)
# Useful for development or when APIs are rate-limited
VITE_DEMO_MODE=false

# Data refresh interval in milliseconds (default: 60000 = 1 minute)
VITE_REFRESH_INTERVAL=60000
